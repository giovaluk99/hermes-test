#!/usr/bin/env bash
# hermes-sub — run the Agent37 Hermes instance on your Claude Max SUBSCRIPTION
# (OAuth), with the Zhiyun API key kept as a chat-switchable fallback.
#
#   ./hermes-sub status            show current inference mode + token state
#   ./hermes-sub enable <TOKEN>    one-time restructure -> subscription default,
#                                  Zhiyun moved to a `zhiyun` custom_provider.
#                                  <TOKEN> = output of `claude setup-token` (sk-ant-oat01-…)
#
# After `enable`, switch in chat with Hermes' built-in command:
#   /model claude-sonnet-4-6 --provider anthropic        → subscription (default)
#   /model claude-opus-4-8   --provider anthropic        → subscription, opus
#   /model claude-sonnet-4-5-20250929 --provider zhiyun  → Zhiyun API (their 4-6 is broken; stay on 4-5)
#
# Why subscription works: native `anthropic` provider + an OAuth-shaped token
# (sk-ant-…) + NO base_url override → Hermes' is_oauth path fires (Claude Code
# identity, mcp__ tool names, oauth betas) → billed against the Max plan, not
# extra usage. Verified: HTTP 200 / service_tier=standard, incl. tool calls.
# The blocker before was ANTHROPIC_BASE_URL=zhiyun (a third-party endpoint),
# which disables the OAuth branch. Setup tokens are long-lived and have a
# SEPARATE refresh lineage from your local Pi login, so this never clobbers Pi.
set -euo pipefail
cd "$(dirname "$0")"
A37=./a37
MODEL="anthropic/claude-sonnet-4-6"

case "${1:-status}" in
status)
  $A37 'cd /usr/local/lib/hermes/hermes-agent && venv/bin/python - <<"PY"
import os, re, pathlib
env = pathlib.Path.home()/".hermes/.env"
e = dict(re.findall(r"^([A-Z_]+)=(.*)$", env.read_text(), re.M)) if env.exists() else {}
base = e.get("ANTHROPIC_BASE_URL","")
tok  = e.get("CLAUDE_CODE_OAUTH_TOKEN","")
from agent.anthropic_adapter import resolve_anthropic_token, _is_oauth_token
os.environ.update({k:v for k,v in e.items()})
rt = resolve_anthropic_token() or ""
mode = "SUBSCRIPTION (OAuth)" if (_is_oauth_token(rt) and "anthropic.com" in (base or "https://api.anthropic.com")) else ("API (third-party: %s)"%base if base else "API")
print("inference mode :", mode)
print("resolved token :", rt[:16]+"…" if rt else "(none)")
print("is_oauth       :", _is_oauth_token(rt))
print("base_url       :", base or "(api.anthropic.com)")
print("setup token set:", bool(tok))
import yaml; cfg=yaml.safe_load((pathlib.Path.home()/".hermes/config.yaml").read_text())
print("default model  :", cfg.get("model"))
print("providers      :", [p.get("name") for p in cfg.get("custom_providers",[])])
PY'
  ;;
enable)
  TOKEN="${2:-}"
  [[ "$TOKEN" == sk-ant-* ]] || { echo "usage: ./hermes-sub enable <setup-token>  (run 'claude setup-token' to get one)"; exit 2; }
  echo "→ restructuring instance for subscription default + zhiyun fallback…"
  $A37 "cd /usr/local/lib/hermes/hermes-agent && CC_TOKEN='$TOKEN' MODEL='$MODEL' venv/bin/python - <<'PY'
import os, re, pathlib, yaml
home = pathlib.Path.home()
envf = home/'.hermes/.env'; envf.touch(); envf.chmod(0o600)
lines = envf.read_text().splitlines()
e = dict(l.split('=',1) for l in lines if '=' in l and not l.lstrip().startswith('#'))
zkey, zbase = e.get('ANTHROPIC_API_KEY',''), e.get('ANTHROPIC_BASE_URL','')

# 1) move Zhiyun (if present) into a named custom_provider so chat can switch to it
cfgf = home/'.hermes/config.yaml'; cfg = yaml.safe_load(cfgf.read_text()) or {}
cps = cfg.setdefault('custom_providers', [])
if zbase and not any(p.get('name')=='zhiyun' for p in cps):
    cps.append({'name':'zhiyun','base_url':zbase,'api_key':zkey,
                'api_mode':'anthropic_messages','model':'claude-sonnet-4-5-20250929'})
    print('  + added zhiyun custom_provider')
cfg['model'] = os.environ['MODEL']
cfgf.write_text(yaml.safe_dump(cfg, sort_keys=False)); cfgf.chmod(0o600)

# 2) clean .env: drop the native-anthropic overrides, set the OAuth setup token
keep = [l for l in lines if not re.match(r'^(ANTHROPIC_BASE_URL|ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN)=', l)]
keep.append('CLAUDE_CODE_OAUTH_TOKEN=' + os.environ['CC_TOKEN'])
envf.write_text('\n'.join(keep)+'\n'); envf.chmod(0o600)
print('  + set CLAUDE_CODE_OAUTH_TOKEN, removed ANTHROPIC_BASE_URL/ANTHROPIC_API_KEY')

# 3) harden: re-assert the whole subscription state on EVERY boot. The token has
#    been wiped before (a reset/another session reverted .env to Zhiyun). This
#    runs after Agent37's configure-hermes-config force, before the gateway.
# generated hook is ALL-PYTHON (no bash $ vars) so the local shell can't expand it.
hook = home/'.agent37/hooks/post-restart.sh'; hook.parent.mkdir(parents=True, exist_ok=True)
hook.write_text(f'''#!/usr/bin/env bash
# Re-assert Claude Max subscription (OAuth) every container start. Generated by hermes-sub.
hermes config set model {os.environ['MODEL']} >/dev/null 2>&1 || true
python3 - <<'PYEOF' || true
import pathlib, re, yaml
home = pathlib.Path.home()
e = home/'.hermes/.env'; e.touch()
ls = [l for l in e.read_text().splitlines() if not re.match(r'^(ANTHROPIC_BASE_URL|ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN)=', l)]
ls.append('CLAUDE_CODE_OAUTH_TOKEN={os.environ['CC_TOKEN']}')
e.write_text(chr(10).join(ls)+chr(10)); e.chmod(0o600)
c = home/'.hermes/config.yaml'; cfg = yaml.safe_load(c.read_text()) or {{}}
cps = cfg.setdefault('custom_providers', [])
if not any(p.get('name')=='zhiyun' for p in cps):
    cps.append({{'name':'zhiyun','base_url':{zbase!r},'api_key':{zkey!r},'api_mode':'anthropic_messages','model':'claude-sonnet-4-5-20250929'}})
    c.write_text(yaml.safe_dump(cfg, sort_keys=False)); c.chmod(0o600)
PYEOF
''')
hook.chmod(0o755)
print('  + hardened post-restart.sh (re-asserts token+model+zhiyun each boot)')
print('  default model:', cfg['model'])
PY"
  # persistence: .env lives on the persistent volume AND post-restart.sh re-asserts
  # the full subscription state on every boot, so a reset can't silently drop it.
  echo "→ restarting gateway (supervisor respawns it with the new env)…"
  $A37 'pkill -f "hermes gateway run" || true' >/dev/null 2>&1 || true
  sleep 6
  $A37 'ps aux | grep "hermes gateway run" | grep -v grep | head -1 | sed "s/  */ /g" | cut -d" " -f11-' 2>&1
  echo "→ status:"
  "$0" status
  ;;
*) sed -n '2,18p' "$0"; exit 0 ;;
esac
