#!/usr/bin/env bash
# Re-assert Claude Max subscription (OAuth) every container start. Generated by hermes-sub.
hermes config set model anthropic/claude-sonnet-4-6 >/dev/null 2>&1 || true
# re-apply OAuth system-prompt relocation patch (ephemeral lib)
# re-apply all persisted lib patches (lib is on the ephemeral overlay)
for p in /home/node/.agent37/patches/*.py; do [ -f "$p" ] && /usr/local/lib/hermes/hermes-agent/venv/bin/python "$p" >/dev/null 2>&1 || true; done
python3 - <<'PYEOF' || true
import pathlib, re, yaml
home = pathlib.Path.home()
e = home/'.hermes/.env'; e.touch()
ls = [l for l in e.read_text().splitlines() if not re.match(r'^(ANTHROPIC_BASE_URL|ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN)=', l)]
ls.append('CLAUDE_CODE_OAUTH_TOKEN=<<CLAUDE_CODE_OAUTH_TOKEN>>')
e.write_text(chr(10).join(ls)+chr(10)); e.chmod(0o600)
c = home/'.hermes/config.yaml'; cfg = yaml.safe_load(c.read_text()) or {}
cps = cfg.setdefault('custom_providers', [])
if not any(p.get('name')=='zhiyun' for p in cps):
    cps.append({'name':'zhiyun','base_url':'https://api1.zhiyunai168.com','api_key':'<<ZHIYUN_API_KEY>>','api_mode':'anthropic_messages','model':'claude-sonnet-4-5-20250929'})
    c.write_text(yaml.safe_dump(cfg, sort_keys=False)); c.chmod(0o600)
PYEOF
